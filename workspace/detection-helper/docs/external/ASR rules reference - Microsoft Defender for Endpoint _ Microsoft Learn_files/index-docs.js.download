earch";var cX="{productName} feedback",uX="{productName} is an open source project. Select a link to provide feedback:";var dX="Open Cloud Shell",pX="Optional";var GA="{label} (optional)";var mX="An error occurred",gX='We ran into an expected error. Please try again. If you believe this is a mistake, feel free to contact account representative or <a href="https://learn.microsoft.com/training/support/troubleshooting#report-feedback">customer support</a>.',fX="The data share you requested is already setup",hX="Do you wish to proceed to view this data share?",bX="Not at this time",_X="Sending data share invitation...",yX="Microsoft Learn Data Sharing Agreement",vX='I acknowledge and accept the <a href="https://learn.microsoft.com/legal/training/reporting/terms">Microsoft Learn Data Sharing Pilot Terms</a> to enable Microsoft to share Learn data with my organization for Learn users signing in with my organization\u2019s tenant ID.',xX="Try again with your linked work account",TX="We could not verify your account",wX='Please sign-in with your work account to access this data share. If you believe this is an error, please contact <a href="https://learn.microsoft.com/training/support/troubleshooting#report-feedback">customer support</a> or contact your account representative.',SX="Yes, please",sa="Other";var CX="Overall, how satisfied or dissatisfied are you with Microsoft Learn?";var VA="Package",MN="{platformName} Package Reference";var jA="Page {pageNumber} of {numberOfPages}";var EX="pagination";var AX="Parameters";var kX="Your PDF has been generated. Opening for you...";var IX="Phone number",Eu="Plan";var PX="Please fill out this field.";var LX="Please provide feedback on how we can improve this content. If applicable, provide the first part of the sentence or string at issue.";var RX="Popular";var MX="Print";var DX="Print is disabled for content requiring authorization.",QA="Privacy policy",$X="Poor";var Gf="Preview";var tl="Previous";var Vf="Product",NX="{productName} users:";var jf="Products",FX="Profile";var UX="Programming language",OX="Programming languages";var qX="Provide product feedback";var Hv="Q&A";var HX="asked";var BX="answers",zX="comments";var GX="votes";var VX=`We appreciate your patience as we migrate Microsoft Support Community content to Microsoft Q&A. We're not migrating all the content, and the question you're looking for has been retired. For more information about the migration, see <a href="https://aka.ms/QAMigration">Learn More</a>. You can <a href="/answers/questions/ask/">re-ask the question</a> or explore other questions on the <a href="{productPageUrl}">{product}</a> page.`,jX="This question has been retired";var QX="Maximum number of attachments exceeded. Please select up to {maximumCount} attachments.";var YX="Maximum number of mentions exceeded. Please select up to {maximumCount} mentions.";var WX="User is already suspended. Please refresh the page.",KX="User is not suspended. Please refresh the page.";var JX="You cannot take this action because your account has been suspended due to a violation of our Code of Conduct. Your account was manually reported or identified through automated detection before action was taken. Please refer to our Code of Conduct for more information.";var ZX="This answer was helpful",XX="This answer was not helpful";var DN="Report a concern",$N="Report reason";var eee=`<a class='docs-sign-in' href="#">Sign in</a> to opt into email updates on your reported concern`,tee="Allow Microsoft to contact me about this report",nee="Full Name",oee="Email",ree='We will contact you through your personal account <span id="report-msa-email-account" class="font-weight-bold">{email}</span>',see='Microsoft is committed to helping our users and to protecting your privacy. You may read the <a href="https://privacy.microsoft.com/privacystatement">Microsoft Privacy Statement</a> if you would like more information on how we protect personal data.';var iee="Question",Mp="Question author",NN='<p><span class="font-weight-semibold">Question author filtering</span></p><p>When filtering by question author, you can only filter by <span class="font-weight-semibold">one user</span> at a time and only filter by <span class="font-weight-semibold">Learn users.</span></p>',FN="Questions";var aee="Question already answered.";var lee="Required question.",cee="Optional question.",uee="Quick Filters";var UN="Read in English",dee="Read in {language}";var pee="Recommended content",jo="Reference";var mee="References";var Au="Refresh";var Qf="Remove",ON="Remove {itemName}";var qN="Renew";var YA="Report a concern",gee="Select reason",fee="Adult and sexual",hee="Child sexual exploitation and abuse imagery",bee="Coordination of harm";var _ee="Bullying and harassment",yee="Graphic violence and gore",vee="Hate speech and discrimination",xee="Non-consensual intimate imagery & intimate extortion";var Tee="Other Terms of Use or Code of Conduct violation";var wee="Profanity and vulgarity",See="Sexual solicitation";var Cee="Suicide and self-injury",Eee="Terrorism and violent extremism",Aee="Trafficking",kee="Violent threats, incitement, and glorification of violence";var Iee="Request Preview",HN="Request URL";var ia="Required fields are marked with an asterisk";var Pee="Types";var Lee="Response Code";var BN="Restart";var Ree="{numberOfResults} results";var Yf="Resume",WA="Retake";var Mee="Role";var Dee="Learning path";var $ee="Roles";var Nee="RSS",Fee="Run";var KA="We're encountering an issue with the security verification process required to activate the resource. Please retry after 10 minutes.",zN=`We have reviewed your appeal and determined that your account has violated our <a href="https://learn.microsoft.com/en-us/legal/termsofuse" data-linktype="external">Terms of Use</a>. Your interactive resource access will not be reinstated. However, you can continue to access Microsoft Learn's training content. Many module exercises can be completed using your personal subscription, but charges may apply, and you may need to modify the instructions to work with your subscription.`;var tt="Save";var Uee="Skill";var GN="Add to plan",VN="Added to Plans",Oee="Manage {title} in Plans",qee="Add {title} to a plan";var jN="Copy plan",Hee="Days to milestone: {number}";var Bee="Estimated time to complete: {time}";var zee="{number} milestone(s) in this plan";var Gee="Milestone {number}",Vee='Added to <a href="{url}" class="has-text-tertiary-invert text-decoration-underline">{collectionName}</a>',jee='Added to <a href="{url}" class="has-text-tertiary-invert text-decoration-underline">Plans</a>',Qee="Sign in to Microsoft Learn to use AI to build a personalized and tailored learning plan that considers your unique needs and provides the most relevant content.",Yee='Removed from <a href="{url}" class="has-text-tertiary-invert text-decoration-underline">{collectionName}</a>',Wee='Removed from <a href="{url}" class="has-text-tertiary-invert text-decoration-underline">Plans</a>',JA="Background",Kee="Current role",Jee="Choose a role",ZA="Provide your career background information.",Zee="Provide your detailed title and responsibilities",Xee="What's your career stage?",ete="Early career (0-5 years)",tte="Mid-career (5-10 years)",nte="Advanced career (10+ years)",ote="Build your plan",rte="{AppliedSkills} (scenarios-based, interactive lab assessments)",ste="Complete a challenging project at work",ite="Earn a professional credential in your field",ate="Enhance a skillset, such as learning a new software tool or programming language",lte="Enter project technologies, goals, and success metrics",cte="Hold down Ctrl button on Windows/Command button on Mac to select multiple options.",ute="Provide project details",dte="Scenario-based credentials that are earned through practical, interactive lab assessments demonstrating your proficiency and ability to implement a real-world solution.";var QN="Select category",Bv="Select certification",pte="Select credential",XA="Select a skill",YN="Select subject",mte="Select type of credential",gte="What are your career goals?",fte="Choose your plan goal",e0="Complete a specific project",hte="Provide a detailed project description including a problem statement and the expected outcome along with technologies, frameworks, languages, or services that you're using.",bte="Provide your detailed title and responsibilities",_te="What is the project goal, problem, and expected outcome? Include any technologies, frameworks, languages, and services that you're using.",yte="Dos and don'ts when describing the project",vte=`<strong>Do:</strong> "I'm developing a web-based application that leverages machine learning algorithms to predict inventory needs, track stock levels in real-time, and automate reordering processes.<br /><br />The main features are real-time inventory tracking, predictive analytics, automated reordering and a reporting/analytics.<br /><br />Technologies we will use are Microsoft Blazor for the frontend user interface, ASP.NET Core for server-side logic and API requests, Azure Cosmos DB for storing inventory data and transactions, Azure Machine Learning and Azure cloud services."`,xte=`<strong>Don't:</strong> "I need to build an inventory tracking web app."`,Tte='Take a few minutes to help us build your learning plan with AI\u2014personalized to you! Microsoft will never share this data. Please read the <a href="/training/support/plans-transparency-note">AI transparency notes</a> to learn more about use cases and limitations and <a href="https://privacy.microsoft.com/privacystatement">privacy policy</a>.',t0="Earn a credential",wte="How do you want to gain credentials?",Ste="Validate skills through a scenario-based assessment",n0="Select the most relevant {AppliedSkills}",Cte="Earn an industry-recognized, role-based Microsoft certification",o0="Industry-recognized certifications",r0="Hmm, something went wrong. Please try again.",Ete="The plan wasn't generated because the form might include wording that may be in violation of Microsoft Learn code of conduct. Please start over and change your phrasing.",Ate="Unfortunately, we couldn't generate your plan. Please start over.",kte="We couldn't open your plan. Please try again.",Ite="We couldn't find credentials for this role. Please select a different role and try again.",s0="Enter detailed title and responsibilities which can help our AI system to better personalize your learning plan. We recommend adding your job title and details about specific tasks you perform which relate to your plan goal";var Pte="Give as many details as you can, but don't include any private or sensitive information",WN="Is this plan helpful?",Lte="Prompts and generated responses will be shared. Preview what will be shared {here}",KN="This plan is helpful",JN="This plan is not helpful",Rte="We appreciate you taking the time to rate the suggested plan and provide comments. Your input will help us improve our experience.",Mte="What about the plan could be improved?",Dte="What did you like about the plan?",$te="Goal",Nte="Generate plan",i0="Generating your plan...",Fte="Almost there",Ute="Almost there - we're just putting the final touches to ensure everything is perfect!",Ote="Completion time",qte="Now, we're estimating milestone completion time based on your learning pace.",Hte="Next, we're outlining your learning outcomes.",Bte="Lastly, we're setting milestones including key stages and checkpoints.",zte="First, we're generating your plan title and description that'll define the purpose and scope of your project.",Gte="Title and description",a0="Grow in current career",Vte="How does it work?",jte='Each AI-generated plan is based on your selections and the info you provided. We curate relevant content from Microsoft to create a personalized plan. This plan includes tailored training and documentation, organized milestones, progress tracking tools for individuals or groups, and recognition upon completion. Learn more about how <a class="font-weight-normal" href="https://learn.microsoft.com/en-us/training/support/plans-transparency-note">AI plan generation</a> works and its limitations.',Wf="Objectives",l0="Provide more information about your career goals.",c0="Start a new career",Qte="Enter detailed title and responsibilities. We recommend using specific job title(s) and/or detailed responsibilities that relate to your plan goal. This helps our AI system to be more personalized and accurate.",Yte="Role description",Wte="Select role",Kte="Select the most relevant role",Jte="What role are you interested in exploring?",Zte="Start over without saving",Xte="Start over without saving your plan?",ene="If you start over, the plan and info you entered won't be saved, and you'll need to reenter your details and preferences.",tne="Take a few minutes to help us build your learning plan with AI\u2014personalized to you!",zv="Tell us your goal",nne="Add as much information and detail as possible",one='Example: "My goal is to become proficient in Azure AI services. I want to learn how to build, deploy, and manage AI models using Azure Machine Learning. Additionally, I aim to understand how to integrate these models into our existing applications to enhance their capabilities and provide better insights."',Gv="Timeline",Vv="Let us know how much time you have to work on your plan.",rne="How much time can you dedicate weekly?",sne="When do you want to finish your learning plan?",ine="Less than 1 hour",ane="1-2 hours",lne="3-5 hours",cne="5-10 hours",une="More than 10 hours",dne="Within 3 months",pne="3-6 months",mne="6-12 months",gne="More than 12 months";var Kf="Review plan";var fne="Success! Your new plan is ready. Please review as AI-generated content may be inaccurate.";var hne="Example plan",bne="This skilling plan guides you through developing AI solutions using Azure AI Services, focusing on natural language processing, generative AI, and custom AI applications. You'll learn to leverage Azure's powerful tools and services effectively.";var _ne="By the end of this plan, you'll be able to create and deploy AI solutions using Azure AI Services, including natural language processing and generative AI applications.",yne="By the end of this plan, you'll be able to implement custom AI applications using Azure OpenAI Service and Azure AI Studio.",vne="By the end of this plan, you'll be able to develop intelligent applications that utilize Azure AI capabilities for various use cases.",xne="Learn foundational Azure AI services",Tne="In this section, learners will explore the basics of Azure AI Services, gaining foundational knowledge to build AI solutions. Key technologies include Azure AI Services, with tasks such as understanding service capabilities and initial setup.",wne="Get started with Azure AI Services",Sne="Develop advanced AI solutions with Azure",Cne="This section focuses on developing advanced AI solutions, including natural language processing and generative AI. Learners will work with Azure AI Services and Azure OpenAI Service, engaging in tasks like building language models and creating custom copilots.",Ene="Develop natural language processing solutions with Azure AI Services",Ane="Develop applications with Azure OpenAI in Foundry Models",kne="Develop your own custom copilots with Azure AI Studio",Ine="Develop AI Solutions with Azure AI Services",Pne='<a href="{url}" class="has-text-tertiary-invert text-decoration-underline">Plans</a> updated';var Lne="Choose a different name for your plan",Rne="Copy Link";var u0="Manage";var d0="Leave",Mne="Leave plan",Dne="Are you sure you want to leave this plan?",$ne="You'll lose all records of your progress, and won't appear in the creator's report.",Nne="Yes, leave",Fne="Enter a title";var Une="Sorry, this plan is private.",One="The creator of this plan has marked it as private and it is not currently visible to other users.",qne="You can review your Plans in your user profile.",Hne="View your Plans",Bne='You can also return to <a href="{url}" class="color-text text-decoration-underline">Plans</a>.',zne="Plan unavailable",Gne="This plan does not exist or was removed.",Vne="If this link was shared with you, request a new link.",jne="Completed";var Qne="A plan allows learners to progress through a set of milestones to achieve learning outcomes. You can invite learners to your plan and track their progress.",Yne="Started";var Wne="Official plan";var Kne="Plan not found. Please refresh the page.",Jne="One or more milestones is empty or is missing the recommended days to complete. Please fix these issues before publishing the plan.",Zne="Plan details";var Xne="Delete plan",eoe="To delete your plan, ensure no users are joined to it. All users must drop the plan first.",toe="Are you sure that you want to delete the following plan?",noe="Yes, delete plan";var Jf="Invite learners",ZN="Copy invite link",ooe="Link copied to clipboard",roe="Delete learning group",soe="You are about to delete the following learning group: <strong>{learningGroupName}</strong>. Do you want to proceed?",ioe="Group deleted",aoe="Groups",jv="Group name",loe="Individuals";var coe="A learning group is a name that allows you to identify a group of learners in your progress report; learners will not see this name.<br/><br/>Creating a learning group generates a unique link to your plan for the specific group of learners.";var XN="New learning group",uoe="Please enter a name for this learning group",doe="Your invitation to start {planTitle} plan on Microsoft Learn",poe="Start your plan and begin your learning journey today.",moe="You have been invited to start the {planTitle} plan on Microsoft Learn.",goe="A plan is a set of curated and organized content on Microsoft Learn with milestones designed to help you to achieve learning outcomes.",foe="By completing this plan, you\u2019ll achieve the following learning outcomes:",hoe="Start your plan today!",Zf="View progress",boe="Download this file to view a list of learners and their progress.",p0="Download CSV",_oe="The file contains the following information:",yoe="Learner group",voe="Learn username",xoe="Start date",Toe="End date",woe="Items completed",Soe="Items total",ku="Learning outcomes",Coe="Edit learning outcomes",Eoe="A learning outcome is specific knowledge, skills, or expertise that the learner will get from completing this plan.",Aoe="Tip: Begin each learning outcome with a verb. Each outcome should finish the sentence \u201CUpon completion of this plan, learners will be able to...\u201D";var koe="Outcome 1",Ioe="Outcome 2 (optional)",Poe="Outcome 3 (optional)",Loe="Outcome {number}",Roe="Convert to an official plan",Moe="Convert a plan to an official plan",Doe="An official plan should be used when you want your plan to <strong>represent Microsoft</strong> and if you would like to include links that are external to Microsoft Learn. Always ensure that your plan is complete, free of typographical errors, and that content is in the correct sequence. <strong>Once an official plan is published, it cannot be altered.</strong>",$oe="To preserve any external links from an underlying Official Collection or plan, please convert to an official plan.",Noe="An official plan represents Microsoft, so please ensure that your published plan is complete, free of typographical errors, and that content is in the correct sequence.";var m0="This plan has been submitted to be localized",Foe="The plan is complete and proofread",Uoe="Thank you for submitting your official plan for localization.",Ooe="Mark as completed",e2="Milestone",qoe="Add milestone",Hoe="Edit milestone";var Boe="New milestone",zoe="Days to milestone:",Goe="1 milestone",Voe="{numberOfMilestones} milestones";var joe="Milestone completed";var Qoe="Move to";var Yoe="Please confirm all milestones have a title and days to complete. You may need to expand each milestone.";var Woe="Mark as complete?",Koe="Do you want to mark it complete? Once you mark it as complete, you won't be able to re