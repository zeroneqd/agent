t-weight-semibold">Welcome</span> to Microsoft Learn!';var nae="What is the reason for your feedback?";var oae='with AI on Microsoft Learn <span class="icon" aria-hidden="true"><span class="docon docon-sparkle gradient-text-vivid"></span></span>';var rae="Windows Documentation";var ih="x.com",S2="{totalXP} XP";var sae="Year",C2="Years";var vi="Yes",Up="Yes, delete";var iae="You don't have any collections yet.";var aae="You must select between {min} and {max} {tagLabel}.",lae="`{tagLabel}` is no longer in use. Use a different tag that applies to your scenario.";var cae="Your Account";var uae="MSDN TechNet has been retired and this article no longer exists. The following links have related information:",dae="Archived TechNet Wiki content",pae="Archived MSDN and TechNet forums";var mae="Microsoft Learn documentation",gae="Microsoft Learn home page",fae="Microsoft Q&A";var Op=window;var q=Op,ah=Op.navigator,w=Op.document,hae=Op.localStorage,Qo=Op.history,J=Op.location,b=q.msDocs,Ce=new Promise(e=>{w.readyState==="loading"?w.addEventListener("DOMContentLoaded",()=>e()):e()});A();function kt(){window.dispatchEvent(new CustomEvent("content-update"))}function Wt(e,t,n="",o="button-info",r="banner",s){let i=s||w.getElementById("disclaimer-holder");if(!i||w.getElementById("server-disclaimer-holder"))return null;let l=t&&t.url?d`
					<a
						id=${t.id}
						href="${t.url}"
						data-bi-name="CTA"
						class="button ${o} button-sm margin-inline-xxs"
					>
						<span>${t.text}</span>
					</a>
			  `:"",c=t&&t.clickHandler?d`
					<button
						id=${t.id}
						data-bi-name="CTA"
						@click="${t.clickHandler}"
						class="button ${o} button-sm margin-inline-xxs"
					>
						${t.text}
					</button>
			  `:"",u=t?d` <div class="level-right margin-xxs margin-none-tablet">
				<div class="level-item justify-content-flex-start padding-xxs-tablet">
					${l||c}
				</div>
		  </div>`:"";return v(d`
			<section
				data-bi-name="${r}"
				data-dismissable="disappearing"
				class="${n} banner"
			>
				<div class="banner-content uhf-container display-flex align-items-center">
					<div class="level justify-content-flex-start margin-bottom-none">
						<div class="level-left flex-shrink-1">
							<div class="level-item flex-shrink-1">
								<p
									class="has-text-white-static disclaimer-title margin-block-xxs margin-right-xs has-line-height-reset"
								>
									<span class="icon" aria-hidden="true"
										><span class="docon docon-status-error-outline"></span
									></span>
									<span>${F(e)}</span>
								</p>
							</div>
						</div>
						${u}
					</div>
					<button
						data-dismiss
						data-bi-name="close"
						type="button"
						class="delete position-absolute top-0 right-0 margin-xxs delete-lg"
					>
						<span class="visually-hidden">${na}</span>
					</button>
